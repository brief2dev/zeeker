# Fuerza a Git a almacenar todo con saltos LF (compatibles con Linux/macOS)
* text=auto eol=lf

# Asegura formato LF en código fuente
*.php text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf

# Si usas scripts o archivos especiales de Windows
*.bat text eol=crlf
*.cmd text eol=crlf

# Binarios (no tocar saltos de línea)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.ico binary
